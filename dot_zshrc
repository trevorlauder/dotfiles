# Use path array for cleaner manipulation and uniqueness.
typeset -U path PATH

# Helper for adding paths: path_add <prepend|append> paths...
path_add() {
  local mode=$1; shift
  local p
  for p in "$@"; do
    [[ -d $p ]] || continue
    case $mode in
      prepend) path=($p $path) ;;
      append)  path+=($p) ;;
    esac
  done
}

path_add append \
  "${HOME}/.local/bin" \
  "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"

alias cat='bat --paging=never'

autoload -Uz compinit
if [[ -z ${ZSH_COMPDUMP:-} || ! -f ${ZSH_COMPDUMP} ]]; then
  compinit
else
  compinit -C
fi

source "${HOME}/.zgen/zgen.zsh"

if ! zgen saved; then
  zgen oh-my-zsh
  zgen oh-my-zsh plugins/git
  zgen load zsh-users/zsh-syntax-highlighting
  zgen load zsh-users/zsh-autosuggestions
  zgen save
fi

if ! command -v brew >/dev/null 2>&1; then
  if [[ "$(uname -s)" == linux* ]]; then
    brew_cmd=/home/linuxbrew/.linuxbrew/bin/brew
  elif [[ "$(uname -s)" == "Darwin" ]]; then
    brew_cmd=/opt/homebrew/bin/brew
  fi

  if [[ -x ${brew_cmd} ]]; then
    export HOMEBREW_NO_ENV_HINTS=1
    eval "$(${brew_cmd} shellenv zsh)"
  fi
fi

if command -v brew >/dev/null 2>&1; then
  # OpenSSL build flags (Homebrew OpenSSL 3).
  export LDFLAGS="-L$(brew --prefix)/opt/openssl@3/lib"
  export CPPFLAGS="-I$(brew --prefix)/opt/openssl@3/include"
  export PKG_CONFIG_PATH="$(brew --prefix)/opt/openssl@3/lib/pkgconfig"

  path_add prepend \
    $(brew --prefix)/opt/{coreutils,findutils,gawk}/libexec/gnubin \
    $(brew --prefix)/opt/openssl@3/bin
fi

export MISE_GLOBAL_CONFIG_FILE="${HOME}/.config/mise/conf.d/900-dotfiles.toml"
eval "$(mise activate zsh)"

export GITHUB_TOKEN=$(gh auth token)

if command -v fzf >/dev/null 2>&1; then
  source <(mise exec fzf -- fzf --zsh)
fi

# Per-machine or secret values: $HOME/.dotfiles-local-settings (optional)
[[ -f "$HOME/.dotfiles-local-settings" ]] && source "$HOME/.dotfiles-local-settings"

function set_win_title(){
  echo -ne "\033]0; $(basename "$PWD") \007"
}

precmd_functions+=(set_win_title)

if [[ "${DEVCONTAINER}" == "true" ]]; then
  export HISTFILE="/commandhistory/.zsh_history"
else
  export HISTFILE="${HOME}/.zsh_history"
fi

export HISTFILESIZE=10000
export HISTSIZE=10000
export SAVEHIST=10000

setopt APPEND_HISTORY INC_APPEND_HISTORY SHARE_HISTORY

unset -f path_add

eval "$(starship init zsh)"
