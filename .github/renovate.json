{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "mise": {
    "managerFilePatterns": [
      "/dot_config/mise/conf\\.d/100-dotfiles.toml.tmpl$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "matchManagers": [
        "mise"
      ],
      "groupName": "mise"
    },
    {
      "matchManagers": [
        "dprint"
      ],
      "groupName": "dprint"
    }
  ]
}
